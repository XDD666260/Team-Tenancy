<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgLight">

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingBottom="24dp">

            <!-- ==================== 价格分布 ==================== -->
            <LinearLayout
                android:id="@+id/sectionPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg"
                android:orientation="vertical">

                <!-- 标题栏 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingTop="16dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="12dp">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="18dp"
                        android:background="@color/colorPrimary" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="价格区间分布"
                        android:textColor="@color/textPrimary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <!-- 单价/总价切换 -->
                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/togglePrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:singleSelection="true"
                        app:checkedButton="@+id/btnUnitPrice">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnUnitPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:text="单价"
                            android:textSize="12sp"
                            app:cornerRadius="4dp"
                            style="@style/Widget.Material3.Button.TonalButton" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnTotalPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:text="总价"
                            android:textSize="12sp"
                            app:cornerRadius="4dp"
                            style="@style/Widget.Material3.Button.TonalButton" />
                    </com.google.android.material.button.MaterialButtonToggleGroup>
                </LinearLayout>

                <!-- 价格柱状图 -->
                <com.github.mikephil.charting.charts.BarChart
                    android:id="@+id/barChartPrice"
                    android:layout_width="match_parent"
                    android:layout_height="250dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp" />
            </LinearLayout>

            <!-- 间距 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="12dp" />

            <!-- ==================== 户型分布 ==================== -->
            <LinearLayout
                android:id="@+id/sectionLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg"
                android:orientation="vertical">

                <!-- 标题栏 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingTop="16dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="12dp">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="18dp"
                        android:background="@color/nearbyTag" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="户型分布 + 各户型均价"
                        android:textColor="@color/textPrimary"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- 户型组合图（柱状+折线） -->
                <com.github.mikephil.charting.charts.CombinedChart
                    android:id="@+id/combinedChartLayout"
                    android:layout_width="match_parent"
                    android:layout_height="250dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp" />
            </LinearLayout>

            <!-- 间距 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="12dp" />

            <!-- ==================== 面积分布 ==================== -->
            <LinearLayout
                android:id="@+id/sectionArea"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg"
                android:orientation="vertical">

                <!-- 标题栏 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingTop="16dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="12dp">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="18dp"
                        android:background="@color/recommendTag" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="面积区间分布"
                        android:textColor="@color/textPrimary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <!-- 饼图/柱状图切换 -->
                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/toggleArea"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:singleSelection="true"
                        app:checkedButton="@+id/btnAreaPie">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAreaPie"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:text="饼图"
                            android:textSize="12sp"
                            app:cornerRadius="4dp"
                            style="@style/Widget.Material3.Button.TonalButton" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAreaBar"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:text="柱状"
                            android:textSize="12sp"
                            app:cornerRadius="4dp"
                            style="@style/Widget.Material3.Button.TonalButton" />
                    </com.google.android.material.button.MaterialButtonToggleGroup>
                </LinearLayout>

                <!-- 面积饼图 -->
                <com.github.mikephil.charting.charts.PieChart
                    android:id="@+id/pieChartArea"
                    android:layout_width="match_parent"
                    android:layout_height="250dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:visibility="visible" />

                <!-- 面积柱状图（默认隐藏） -->
                <com.github.mikephil.charting.charts.BarChart
                    android:id="@+id/barChartArea"
                    android:layout_width="match_parent"
                    android:layout_height="250dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- 间距 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="12dp" />

            <!-- ==================== 数据来源 ==================== -->
            <LinearLayout
                android:id="@+id/sectionSource"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="16dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_house"
                    android:contentDescription="数据来源" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="数据来源：安居客、链家等房产平台"
                    android:textColor="@color/textSecondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- 加载指示器 -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:visibility="gone" />

            <!-- 错误提示 -->
            <TextView
                android:id="@+id/tvError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:textColor="@color/priceColor"
                android:textSize="13sp"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

</FrameLayout>
